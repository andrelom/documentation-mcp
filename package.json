{
  "name": "documentation-mcp",
  "version": "1.0.0",
  "description": "Generic, multi-provider MCP server for documentation — scrapes, caches, and serves any documentation site via MCP tools",
  "type": "module",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build": "tsc",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fastmcp": "^3.34.0",
    "jsdom": "^29.0.0",
    "playwright": "^1.58.2",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.5.0",
    "@types/turndown": "^5.0.6",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.29.1"
}
